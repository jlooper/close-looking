---
interface StepView {
  url: string;
  focusX: number;
  focusY: number;
  zoom: number;
}

interface InitialView {
  focusX: number;
  focusY: number;
  zoom: number;
}

interface Props {
  steps: StepView[];
  initialView?: InitialView;
  style?: string;
}

const { steps, initialView, style } = Astro.props;
---

<div
  class="step-sync"
  data-steps={JSON.stringify(steps)}
  data-initial-view={initialView ? JSON.stringify(initialView) : undefined}
  style={style}
>
  <slot />
</div>

<script>
  interface StepView {
    url: string;
    focusX: number;
    focusY: number;
    zoom: number;
  }

  interface InitialView {
    focusX: number;
    focusY: number;
    zoom: number;
  }

  function initStepSync() {
    document.querySelectorAll<HTMLDivElement>('.step-sync').forEach((container) => {
      const views: StepView[] = JSON.parse(container.dataset.steps ?? '[]');
      const initial: InitialView | null = container.dataset.initialView
        ? JSON.parse(container.dataset.initialView)
        : null;
      const img = container.querySelector<HTMLImageElement>('.sticky-media img');
      if (!img || views.length === 0) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const stepEls = container.querySelectorAll<HTMLElement>('[data-step-index]');

      function applyTransform(focusX: number, focusY: number, zoom: number, animate: boolean) {
        if (animate && !prefersReducedMotion) {
          img!.style.transition = 'transform 1.4s cubic-bezier(0.25, 0.1, 0.25, 1), transform-origin 1.4s cubic-bezier(0.25, 0.1, 0.25, 1), opacity 0.5s ease';
        } else {
          img!.style.transition = 'none';
        }
        img!.style.transformOrigin = `${focusX}% ${focusY}%`;
        img!.style.transform = `scale(${zoom})`;
      }

      function applyView(view: StepView, animate: boolean) {
        const srcChanged = !img!.src.endsWith(new URL(view.url).pathname);

        if (animate && !prefersReducedMotion && srcChanged) {
          img!.style.transition = 'opacity 0.5s ease';
          img!.style.opacity = '0';
          setTimeout(() => {
            img!.src = view.url;
            applyTransform(view.focusX, view.focusY, view.zoom, true);
            img!.style.opacity = '1';
          }, 450);
        } else {
          if (srcChanged) img!.src = view.url;
          applyTransform(view.focusX, view.focusY, view.zoom, animate);
          img!.style.opacity = '1';
        }
      }

      function freezeHeroAnimation() {
        const computed = getComputedStyle(img!);
        const currentTransform = computed.transform;
        const currentOrigin = computed.transformOrigin;
        img!.style.animation = 'none';
        img!.style.transform = currentTransform;
        img!.style.transformOrigin = currentOrigin;
      }

      let firstStepFired = false;
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            if (!firstStepFired) {
              firstStepFired = true;
              freezeHeroAnimation();
            }
            const idx = Number((entry.target as HTMLElement).dataset.stepIndex);
            const view = views[idx];
            if (!view) continue;
            applyView(view, true);
          }
        },
        { rootMargin: '-30% 0px -30% 0px', threshold: 0 },
      );

      stepEls.forEach((step) => observer.observe(step));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStepSync);
  } else {
    initStepSync();
  }
</script>

<style>
  .step-sync {
    position: relative;
  }
</style>
