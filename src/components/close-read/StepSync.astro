---
interface Props {
  style?: string;
}

const { style } = Astro.props;
---

<div
  class="step-sync"
  style={style}
>
  <slot />
</div>

<script>
  function initStepSync() {
    document.querySelectorAll<HTMLDivElement>('.step-sync').forEach((container) => {
      const baseImg = container.querySelector<HTMLImageElement>('.layer.base');
      const stepLayers = container.querySelectorAll<HTMLImageElement>('.layer[data-step-layer]');
      const stepEls = container.querySelectorAll<HTMLElement>('[data-step-index]');

      if (!baseImg || stepLayers.length === 0 || stepEls.length === 0) return;

      let activeLayer = -1;

      function activateStep(index: number) {
        if (index === activeLayer) return;
        if (index < 0 || index >= stepLayers.length) return;

        baseImg!.classList.remove('active');
        stepLayers.forEach((layer) => layer.classList.remove('active'));
        stepLayers[index].classList.add('active');

        activeLayer = index;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const idx = Number((entry.target as HTMLElement).dataset.stepIndex);
            activateStep(idx);
          }
        },
        { rootMargin: '-30% 0px -30% 0px', threshold: 0 },
      );

      stepEls.forEach((step) => observer.observe(step));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStepSync);
  } else {
    initStepSync();
  }
</script>

<style>
  .step-sync {
    position: relative;
  }
</style>
