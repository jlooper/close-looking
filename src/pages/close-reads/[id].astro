---
import { getCollection } from 'astro:content';
import CloseReadLayout from '../../layouts/CloseReadLayout.astro';
import StepBlock from '../../components/close-read/StepBlock.astro';
import StepSync from '../../components/close-read/StepSync.astro';
import Footer from '../../components/close-read/Footer.astro';
import { cloudinaryUrl, cloudinaryCropUrl } from '../../lib/cloudinary';

export async function getStaticPaths() {
  const entries = await getCollection('close-reads');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  title, subtitle, description,
  heroPublicId, heroAlt, heroCredit, heroCreditUrl,
  heroSourceWidth, heroSourceHeight,
  steps,
} = entry.data;

const CROP_DISPLAY_WIDTH = 1200;
const baseUrl = cloudinaryUrl(heroPublicId, { crop: 'scale', width: 1200 });

const stepViews = steps.map((step) => {
  if (step.zoom <= 1) return baseUrl;

  const centerX = heroSourceWidth * step.focusX / 100;
  const centerY = heroSourceHeight * step.focusY / 100;
  const cropH = heroSourceHeight / step.zoom;
    const cropW = cropH * 1.33;

  const url = cloudinaryCropUrl(step.publicId, {
    centerX, centerY, width: cropW, height: cropH,
  }, CROP_DISPLAY_WIDTH);
  return url;
});
---

<CloseReadLayout title={title} description={description}>
  <main class="close-read-main">
    <StepSync views={steps.map((s) => ({ focusX: s.focusX, focusY: s.focusY, zoom: s.zoom }))}>
      <div class="steps-track">
        <div class="steps-track__header">
          <h1 class="steps-track__title">{title}</h1>
          {subtitle && <p class="steps-track__subtitle">{subtitle}</p>}
          {heroCredit && <p class="steps-track__credit">{heroCredit}</p>}
        </div>
        {steps.map((step, i) => (
          <StepBlock headline={step.headline} credit={step.credit} index={i}>
            <p>{step.body}</p>
          </StepBlock>
        ))}
      </div>
      <div class="sticky-media">
        <img
          class="layer base"
          src={baseUrl}
          alt={heroAlt}
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
        {stepViews.map((url, i) => (
          <img
            class="layer step-layer"
            data-step-layer={i}
            src={url}
            alt={steps[i].alt}
            loading={i < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ))}
      </div>
    </StepSync>
  </main>

  <Footer credit={heroCredit} creditUrl={heroCreditUrl} />
</CloseReadLayout>

<style>
  .close-read-main {
    position: relative;
  }

  .close-read-main :global(.step-sync) {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 0;
  }

  .sticky-media {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #111;
  }

  .layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transform-origin: center center;
  }

  .layer.base {
    object-fit: contain;
    opacity: 1;
  }

  .layer.step-layer {
    object-fit: cover;
  }

  .steps-track {
    padding: var(--space-m) var(--space-m) var(--space-l);
  }

  .steps-track__header {
    background: var(--color-card);
    color: var(--color-text);
    padding: var(--space-l) var(--space-m);
    margin-bottom: 80vh;
  }

  .steps-track__title {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.4vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: var(--space-xs);
  }

  .steps-track__subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    font-weight: 300;
    color: var(--color-text-muted);
  }

  .steps-track__credit {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  @media (max-width: 859px) {
    .close-read-main :global(.step-sync) {
      display: block;
    }

    .steps-track {
      max-width: 100%;
    }
  }
</style>
